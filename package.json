{
	"name": "youtube-tweak",
	"private": true,
	"version": "1.1.7.1",
	"type": "module",
	"scripts": {
		"dev": "wxt",
		"dev:firefox": "wxt -b firefox",
		"build": "vue-tsc --noEmit && wxt build && tsx build/chrome-crx3.ts",
		"build:edge": "vue-tsc --noEmit && wxt zip -b edge",
		"build:firefox": "vue-tsc --noEmit && wxt zip -b firefox",
		"build:all": "vue-tsc --noEmit && wxt build && tsx build/chrome-crx3.ts && wxt zip -b edge && wxt zip -b firefox",
		"compile": "vue-tsc --noEmit",
		"postinstall": "wxt prepare"
	},
	"devDependencies": {
		"@wxt-dev/auto-icons": "^1.1.0",
		"@wxt-dev/module-vue": "^1.0.2",
		"crx3": "^1.1.3",
		"dotenv": "^17.2.3",
		"prettier": "^3.6.2",
		"sass": "^1.91.0",
		"tsx": "^4.20.6",
		"typescript": "5.9.2",
		"vite-plugin-vue-devtools": "^8.0.1",
		"vue-tsc": "^3.0.6",
		"wxt": "^0.20.26"
	},
	"dependencies": {
		"codejar": "^4.3.0",
		"pinia": "^3.0.3",
		"prismjs": "^1.30.0",
		"vue": "^3.5",
		"vue-i18n": "^11.1.11"
	},
	"overrides": {
		"esbuild": "0.28.1",
		"shell-quote": "1.8.4",
		"tmp": "0.2.7",
		"uuid": "11.1.1"
	}
}
